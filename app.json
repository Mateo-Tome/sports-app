{
  "expo": {
    "name": "QuickClip",
    "slug": "sport-app",
    "jsEngine": "hermes",
    "version": "1.0.3",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "quickclip",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-video",
      "sentry-expo",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow QuickClip to access your camera to record matches.",
          "microphonePermission": "Allow QuickClip to access your microphone to record match audio."
        }
      ]
    ],
    "ios": {
      "bundleIdentifier": "com.mateotome2133.sportapp",
      "buildNumber": "28",
      "associatedDomains": [
        "applinks:quickclipapp.com",
        "applinks:www.quickclipapp.com"
      ],
      "infoPlist": {
        "NSCameraUsageDescription": "QuickClip uses the camera to record match clips with sport-specific overlays.",
        "NSMicrophoneUsageDescription": "QuickClip uses the microphone to record audio with your match clips.",
        "NSPhotoLibraryUsageDescription": "QuickClip allows you to select videos or photos from your library to import into the app.",
        "NSPhotoLibraryAddUsageDescription": "QuickClip saves your recordings to your Photos library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.mateotome2133.sportapp",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "quickclipapp.com",
              "pathPrefix": "/share"
            },
            {
              "scheme": "https",
              "host": "www.quickclipapp.com",
              "pathPrefix": "/share"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "591d53da-7aa5-4094-bcf7-b97d2895c348"
      }
    }
  }
}