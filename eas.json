{
  "cli": {
    "version": ">= 16.18.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_FIREBASE_API_KEY": "@EXPO_PUBLIC_FIREBASE_API_KEY",
        "EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN": "@EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN",
        "EXPO_PUBLIC_FIREBASE_PROJECT_ID": "@EXPO_PUBLIC_FIREBASE_PROJECT_ID",
        "EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET": "@EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET",
        "EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID": "@EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID",
        "EXPO_PUBLIC_FIREBASE_APP_ID": "@EXPO_PUBLIC_FIREBASE_APP_ID",
        "EXPO_PUBLIC_FUNCTIONS_BASE_URL": "@EXPO_PUBLIC_FUNCTIONS_BASE_URL",
        "EXPO_PUBLIC_GET_PLAYBACK_URLS_URL": "@EXPO_PUBLIC_GET_PLAYBACK_URLS_URL",
        "EXPO_PUBLIC_WEB_BASE_URL": "@EXPO_PUBLIC_WEB_BASE_URL",
        "EXPO_PUBLIC_REVENUECAT_IOS_KEY": "@EXPO_PUBLIC_REVENUECAT_IOS_KEY",
        "EXPO_PUBLIC_REVENUECAT_ANDROID_KEY": "@EXPO_PUBLIC_REVENUECAT_ANDROID_KEY",
        "EXPO_PUBLIC_DISABLE_RC": "@EXPO_PUBLIC_DISABLE_RC"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_FIREBASE_API_KEY": "@EXPO_PUBLIC_FIREBASE_API_KEY",
        "EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN": "@EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN",
        "EXPO_PUBLIC_FIREBASE_PROJECT_ID": "@EXPO_PUBLIC_FIREBASE_PROJECT_ID",
        "EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET": "@EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET",
        "EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID": "@EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID",
        "EXPO_PUBLIC_FIREBASE_APP_ID": "@EXPO_PUBLIC_FIREBASE_APP_ID",
        "EXPO_PUBLIC_FUNCTIONS_BASE_URL": "@EXPO_PUBLIC_FUNCTIONS_BASE_URL",
        "EXPO_PUBLIC_GET_PLAYBACK_URLS_URL": "@EXPO_PUBLIC_GET_PLAYBACK_URLS_URL",
        "EXPO_PUBLIC_WEB_BASE_URL": "@EXPO_PUBLIC_WEB_BASE_URL",
        "EXPO_PUBLIC_REVENUECAT_IOS_KEY": "@EXPO_PUBLIC_REVENUECAT_IOS_KEY",
        "EXPO_PUBLIC_REVENUECAT_ANDROID_KEY": "@EXPO_PUBLIC_REVENUECAT_ANDROID_KEY",
        "EXPO_PUBLIC_DISABLE_RC": "@EXPO_PUBLIC_DISABLE_RC"
      }
    }
  },
  "submit": {
    "production": {}
  }
}